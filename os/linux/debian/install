#!/bin/bash

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

log()     { echo -e "${BLUE}[$(date +'%H:%M:%S')]${NC} $1"; }
success() { echo -e "${GREEN}✓${NC} $1"; }
error()   { echo -e "${RED}✗${NC} $1"; exit 1; }
warn()    { echo -e "${YELLOW}⚠${NC} $1"; }

# ================================================================
# basic configuration
# ================================================================

update_system() {
    log "Updating system packages..."
    sudo apt-get update -qq
    sudo apt-get upgrade -y
    success "System updated"
}

setup_hostname() {
    log "Setting up hostname..."
    read -p "Enter server hostname (leave empty to skip): " -r new_hostname
    if [[ -n "$new_hostname" ]]; then
        sudo hostnamectl set-hostname "$new_hostname"
        if ! grep -q "$new_hostname" /etc/hosts 2>/dev/null; then
            echo "127.0.1.1 $new_hostname" | sudo tee -a /etc/hosts > /dev/null
        fi
        success "Hostname set to: $new_hostname"
    else
        log "Skipping hostname configuration"
    fi
}

setup_timezone() {
    log "Configuring timezone..."
    read -p "Configure timezone now? [y/N]: " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        sudo dpkg-reconfigure tzdata
        success "Timezone configured: $(date)"
    else
        local tz
        tz="$(timedatectl show --property=Timezone --value 2>/dev/null || echo 'unknown')"
        log "Skipping — current timezone: $tz"
    fi
}

create_user() {
    log "Creating new sudo user..."
    read -p "Enter new username (leave empty to skip): " -r new_user
    if [[ -n "$new_user" ]]; then
        if id "$new_user" &>/dev/null; then
            warn "User '$new_user' already exists — skipping creation"
        else
            sudo adduser "$new_user"
            sudo usermod -aG sudo "$new_user"
            sudo mkdir -p "/home/$new_user/.ssh"
            sudo chmod 700 "/home/$new_user/.ssh"
            success "User '$new_user' created and added to sudo"
        fi
        warn "Copy your SSH public key before hardening SSH:"
        warn "  ssh-copy-id -i ~/.ssh/id_ed25519.pub $new_user@<server>"
        warn "  (or manually: scp ~/.ssh/id_ed25519.pub $new_user@<server>:~/.ssh/authorized_keys)"
        warn "  chmod 600 ~/.ssh/authorized_keys  (run on the server)"
    else
        log "Skipping user creation"
    fi
}

# ================================================================
# packages
# ================================================================

install_packages() {
    log "Installing packages from packages.txt..."

    if [[ ! -f "$SCRIPT_DIR/packages.txt" ]]; then
        error "packages.txt not found at $SCRIPT_DIR/packages.txt"
    fi

    local packages
    mapfile -t packages < <(grep -v '^#' "$SCRIPT_DIR/packages.txt" | grep -v '^$')

    if [[ ${#packages[@]} -eq 0 ]]; then
        warn "No packages found in packages.txt"
        return
    fi

    log "Installing ${#packages[@]} packages..."
    sudo DEBIAN_FRONTEND=noninteractive apt-get install -y "${packages[@]}" || {
        warn "Some packages failed to install - continuing anyway"
    }

    success "Package installation completed"
}

# ================================================================
# security hardening
# ================================================================

harden_ssh() {
    log "Hardening SSH configuration..."
    warn "This disables root login and password authentication."
    warn "Your SSH public key must already be in authorized_keys before proceeding."
    read -p "Proceed with SSH hardening? [y/N]: " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        log "Skipping SSH hardening"
        return
    fi

    local sshd_d="/etc/ssh/sshd_config.d"
    if [[ -d "$sshd_d" ]]; then
        sudo cp "$SCRIPT_DIR/config/sshd/hardening.conf" "$sshd_d/99-hardening.conf"
        sudo chmod 644 "$sshd_d/99-hardening.conf"
        success "SSH hardening drop-in deployed to $sshd_d/99-hardening.conf"
    else
        # fallback for Debian < 11: patch sshd_config directly
        warn "sshd_config.d not found — patching /etc/ssh/sshd_config directly"
        sudo sed -i 's/^#\?PermitRootLogin .*/PermitRootLogin no/' /etc/ssh/sshd_config
        sudo sed -i 's/^#\?PasswordAuthentication .*/PasswordAuthentication no/' /etc/ssh/sshd_config
        sudo sed -i 's/^#\?AddressFamily .*/AddressFamily inet/' /etc/ssh/sshd_config
    fi

    if systemctl is-active --quiet sshd 2>/dev/null || systemctl is-active --quiet ssh 2>/dev/null; then
        sudo systemctl restart sshd 2>/dev/null || sudo systemctl restart ssh 2>/dev/null || true
        success "SSH daemon restarted with hardened config"
    else
        success "SSH hardening config deployed (sshd not running — will apply if ever started)"
    fi
}

setup_fail2ban() {
    log "Configuring fail2ban..."

    if ! command -v fail2ban-server &>/dev/null; then
        warn "fail2ban not installed — skipping (run install_packages first)"
        return
    fi

    sudo cp "$SCRIPT_DIR/config/fail2ban/jail.local" /etc/fail2ban/jail.local

    sudo systemctl enable fail2ban
    sudo systemctl restart fail2ban
    success "fail2ban configured: 2 retries, progressive banning up to 4 weeks"
}

setup_firewall() {
    log "Applying iptables firewall rules..."
    warn "No inbound ports open. IPv6 fully blocked."
    warn "Edit config/iptables/rules.v4 to open ports if needed."
    read -p "Apply firewall rules? [y/N]: " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        log "Skipping firewall setup"
        return
    fi

    sudo mkdir -p /etc/iptables
    sudo cp "$SCRIPT_DIR/config/iptables/rules.v4" /etc/iptables/rules.v4
    sudo cp "$SCRIPT_DIR/config/iptables/rules.v6" /etc/iptables/rules.v6
    sudo chmod 600 /etc/iptables/rules.v4 /etc/iptables/rules.v6

    sudo iptables-restore /etc/iptables/rules.v4
    sudo ip6tables-restore /etc/iptables/rules.v6

    sudo DEBIAN_FRONTEND=noninteractive apt-get install -y iptables-persistent
    sudo netfilter-persistent save

    success "Firewall rules applied and persisted"
    log "Review with: sudo iptables -S && sudo ip6tables -S"
}

setup_rootkit_tools() {
    log "Configuring rootkit detection..."

    if command -v rkhunter &>/dev/null; then
        sudo rkhunter --propupd --quiet
        success "rkhunter property database initialised"
        log "Run checks: sudo rkhunter --check"
    else
        warn "rkhunter not found — run install_packages first"
    fi

    if command -v chkrootkit &>/dev/null; then
        success "chkrootkit ready — run: sudo chkrootkit"
    else
        warn "chkrootkit not found — run install_packages first"
    fi
}

# ================================================================
# system optimizations
# ================================================================

optimize_system() {
    log "Applying system optimizations..."

    if [[ ! -f /etc/apt/apt.conf.d/99keep-cache ]]; then
        echo 'Binary::apt::APT::Keep-Downloaded-Packages "true";' \
            | sudo tee /etc/apt/apt.conf.d/99keep-cache > /dev/null
        success "APT package cache enabled"
    fi

    if [[ ! -f /etc/apt/apt.conf.d/99parallel ]]; then
        echo 'Acquire::Queue-Mode "host"; Acquire::http::Pipeline-Depth "5";' \
            | sudo tee /etc/apt/apt.conf.d/99parallel > /dev/null
        success "APT parallel downloads enabled"
    fi

    if systemctl list-unit-files fstrim.timer &>/dev/null; then
        sudo systemctl enable fstrim.timer
        success "SSD trim timer enabled"
    fi

    success "System optimizations applied"
}

setup_directories() {
    log "Creating user directories..."
    mkdir -p ~/scripts ~/projects ~/downloads
    success "User directories created"
}

# ================================================================
# main
# ================================================================

main() {
    echo -e "${BLUE}"
    echo "=================================="
    echo "    Debian Post-Install Setup"
    echo "=================================="
    echo -e "${NC}"

    echo "This script will:"
    echo "• Update system packages"
    echo "• Configure hostname and timezone"
    echo "• Create a new sudo user"
    echo "• Install packages from packages.txt"
    echo "• Harden SSH (disable root login + password auth)"
    echo "• Configure fail2ban with progressive banning"
    echo "• Apply iptables firewall (no inbound ports, IPv6 blocked)"
    echo "• Initialise rootkit detection (rkhunter, chkrootkit)"
    echo "• Apply system optimizations"
    echo "• Create standard user directories"
    echo

    read -p "Continue? [y/N]: " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 0
    fi
    echo

    update_system;        echo
    setup_hostname;       echo
    setup_timezone;       echo
    create_user;          echo
    install_packages;     echo
    harden_ssh;           echo
    setup_fail2ban;       echo
    setup_firewall;       echo
    setup_rootkit_tools;  echo
    optimize_system;      echo
    setup_directories;    echo

    success "Debian server setup completed!"
    echo
    echo "Next steps:"
    echo "  1. Reboot: sudo shutdown -r now"
    echo "  2. Verify fail2ban: sudo fail2ban-client status sshd"
    echo "  3. Full security audit: sudo lynis audit system"
    echo "  4. Monitor connections: sudo whowatch"
    echo "  5. Check open services: sudo ss -atpu"
    echo "  6. Remove unused services: sudo apt purge <package>"
    echo "  7. Configure VPN: os/linux/wireguard"
    echo
}

main "$@"
