#!/bin/bash

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

log()     { echo -e "${BLUE}[$(date +'%H:%M:%S')]${NC} $1"; }
success() { echo -e "${GREEN}✓${NC} $1"; }
error()   { echo -e "${RED}✗${NC} $1"; exit 1; }
warn()    { echo -e "${YELLOW}⚠${NC} $1"; }

update_system() {
    log "Updating system packages..."
    sudo pacman -Syu --noconfirm
    success "System updated"
}

detect_aur_helper() {
    if command -v yay &>/dev/null; then
        echo "yay"
    elif command -v paru &>/dev/null; then
        echo "paru"
    else
        echo ""
    fi
}

install_packages() {
    log "Installing packages from packages.txt..."

    if [[ ! -f "$SCRIPT_DIR/packages.txt" ]]; then
        error "packages.txt not found at $SCRIPT_DIR/packages.txt"
    fi

    local packages
    mapfile -t packages < <(grep -v '^#' "$SCRIPT_DIR/packages.txt" | grep -v '^$')

    if [[ ${#packages[@]} -eq 0 ]]; then
        warn "No packages found in packages.txt"
        return
    fi

    local aur_helper
    aur_helper="$(detect_aur_helper)"

    if [[ -n "$aur_helper" ]]; then
        log "AUR helper found: $aur_helper — installing all ${#packages[@]} packages..."
        "$aur_helper" -S --needed --noconfirm "${packages[@]}" || {
            warn "Some packages failed to install - continuing anyway"
        }
    else
        warn "No AUR helper found (yay/paru). Installing official packages only via pacman."
        warn "AUR packages (e.g. visual-studio-code-bin, brave-bin) will be skipped silently."
        warn "Install an AUR helper first: https://github.com/Jguer/yay"
        sudo pacman -S --needed --noconfirm "${packages[@]}" 2>/dev/null || {
            warn "Some packages failed (likely AUR-only) - continuing anyway"
        }
    fi

    success "Package installation completed"
}

optimize_system() {
    log "Applying system optimizations..."

    # enable parallel downloads in pacman
    if ! grep -q "^ParallelDownloads" /etc/pacman.conf; then
        sudo sed -i 's/#ParallelDownloads = 5/ParallelDownloads = 10/' /etc/pacman.conf
        success "Pacman parallel downloads enabled"
    fi

    # enable color in pacman
    if ! grep -q "^Color" /etc/pacman.conf; then
        sudo sed -i 's/#Color/Color/' /etc/pacman.conf
        success "Pacman color output enabled"
    fi

    # enable trim for ssd
    sudo systemctl enable fstrim.timer
    success "SSD trim timer enabled"

    success "System optimizations applied"
}

setup_directories() {
    log "Creating user directories..."
    mkdir -p ~/scripts ~/projects ~/downloads
    success "User directories created"
}

main() {
    echo -e "${BLUE}"
    echo "=================================="
    echo "   Arch Linux Post-Install Setup  "
    echo "=================================="
    echo -e "${NC}"

    echo "This script will:"
    echo "• Update system packages"
    echo "• Install packages from packages.txt"
    echo "• Apply basic system optimizations"
    echo "• Create user directories"
    echo

    read -p "Continue? [y/N]: " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 0
    fi

    update_system
    install_packages
    optimize_system
    setup_directories

    echo
    success "Arch Linux setup completed!"
    echo
    echo "Next steps:"
    echo "• Run 'os/linux/wireguard' to configure VPN"
    echo "• Reboot to ensure all changes take effect"
}

main "$@"
