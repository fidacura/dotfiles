#!/bin/bash
# dispatcher ~ detects distro and delegates to the correct sub-install

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

log()     { echo -e "${BLUE}[$(date +'%H:%M:%S')]${NC} $1"; }
success() { echo -e "${GREEN}✓${NC} $1"; }
error()   { echo -e "${RED}✗${NC} $1"; exit 1; }
warn()    { echo -e "${YELLOW}⚠${NC} $1"; }

SUPPORTED_DISTROS=("arch" "debian")

validate_distro() {
    local distro="$1"
    for supported in "${SUPPORTED_DISTROS[@]}"; do
        [[ "$distro" == "$supported" ]] && return 0
    done
    error "Unsupported distro: '$distro'. Supported values: ${SUPPORTED_DISTROS[*]}"
}

detect_distro() {
    # prefer value passed in from bootstrap ~ but always validate it
    if [[ -n "${LINUX_DISTRO:-}" ]]; then
        validate_distro "$LINUX_DISTRO"
        log "Using distro from environment: $LINUX_DISTRO"
        return
    fi

    if command -v pacman &>/dev/null; then
        LINUX_DISTRO="arch"
    elif command -v apt &>/dev/null || command -v apt-get &>/dev/null; then
        LINUX_DISTRO="debian"
    else
        error "Could not detect Linux distribution (no pacman or apt found)"
    fi

    log "Detected Linux distribution: $LINUX_DISTRO"
}

main() {
    detect_distro

    local sub_install="$SCRIPT_DIR/$LINUX_DISTRO/install"

    if [[ ! -f "$sub_install" ]]; then
        error "No install script found for '$LINUX_DISTRO' at $sub_install"
    fi

    log "Delegating to $LINUX_DISTRO installer..."
    export LINUX_DISTRO
    bash "$sub_install"
}

main "$@"
